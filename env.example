# IQsea — required environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Anon/public key — safe for browser clients and Next.js server components
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only aliases (used by Warden and API routes on the server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Service role key — bypasses RLS. Required for Warden (engine/warden.ts).
# NEVER expose this in the browser or commit it to source control.
SUPABASE_SERVICE_KEY=

# ── Microsoft Graph (email delivery) ─────────────────────────────────────────
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_SENDER_EMAIL=

GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Full base URL of the deployment (used for password-reset link generation).
# Set to https://yourdomain.com in Vercel. Defaults to http://localhost:3000.
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Admin / session
ADMIN_PASSWORD=
SESSION_SECRET=

# ── Warden (Automated Dispatcher) ────────────────────────────────────────────
# Master switch — set to 'true' to enable scheduled brief dispatch.
ENABLE_AUTO_DISPATCH=true
